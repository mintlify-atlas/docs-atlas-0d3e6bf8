  "keyFeatures": [
    "Local-first markdown workspace rooted at Documents/Glyph",
    "TipTap-based rich markdown editor with markdown-aware shortcuts",
    "Recursive sidebar with nested folders and recent files",
    "Command palette and quick-open panel (Cmd/Ctrl+P)",
    "Full-text workspace search",
    "Markdown link navigation between notes",
    "Slash commands for inserting tables, links, and images",
    "PDF and markdown export",
    "Theme switching with light/dark/system modes",
    "Autosave and safe file refresh on external changes",
    "Focus mode for distraction-free writing",
    "Table of contents outline panel",
    "Auto-update via GitHub Releases",
    "macOS and Windows support"
  ],
  "publicApiSurface": [
    "glyph.openDialog(kind: DialogKind)",
    "glyph.pickAsset(kind: 'image' | 'any-file')",
    "glyph.resolveLinkTarget(currentFilePath, href)",
    "glyph.openFolder(dirPath?)",
    "glyph.openDefaultWorkspace()",
    "glyph.openDocument()",
    "glyph.readFile(filePath)",
    "glyph.saveFile(filePath, content)",
    "glyph.createFile(parentDir, fileName)",
    "glyph.renameFile(oldPath, newName)",
    "glyph.deleteFile(targetPath)",
    "glyph.createFolder(parentDir, folderName)",
    "glyph.searchWorkspace(query)",
    "glyph.getSidebarNode(kind, targetPath)",
    "glyph.getSettings()",
    "glyph.updateSettings(patch)",
    "glyph.getAppInfo()",
    "glyph.checkForUpdates()",
    "glyph.downloadUpdate()",
    "glyph.installUpdate()",
    "glyph.onWorkspaceChanged(listener)",
    "glyph.onCommand(listener)",
    "glyph.onExternalFile(listener)",
    "glyph.onUpdateStateChange(listener)",
    "glyph.revealInFinder(targetPath)",
    "glyph.openExternal(path)",
    "glyph.exportMarkdownToPDF(markdown, filename)"
  ]
