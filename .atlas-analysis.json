{
  "projectType": "saas",
  "projectName": "Glyph",
  "projectDescription": "Glyph is a local-first markdown editor and reader for macOS and Windows that keeps your notes as plain files while providing a beautiful, focused writing and reading experience.",
  "theme": "willow",
  "primaryColor": "#7867c9",
  "lightColor": "#4c4c54",
  "darkColor": "#634aa3",
